[
  {
    "type": "console.page/route",
    "properties": {
      "exact": true,
      "path": "/example",
      "component": { "$codeRef": "ExamplePage" }
    }
  },
  {
    "type": "console.page/route",
    "properties": {
      "exact": true,
      "path": "/k8s/ns/:ns/brokerapps/~new",
      "component": { "$codeRef": "CreateBrokerAppPage" }
    }
  },
  {
    "type": "console.resource/create",
    "properties": {
      "model": {
        "group": "broker.arkmq.org",
        "version": "v1beta2",
        "kind": "BrokerApp"
      },
      "component": { "$codeRef": "CreateBrokerAppPage" }
    }
  },
  {
    "type": "console.page/route",
    "properties": {
      "exact": true,
      "path": [
        "/k8s/ns/:ns/broker.arkmq.org~v1beta2~BrokerService",
        "/k8s/all-namespaces/broker.arkmq.org~v1beta2~BrokerService"
      ],
      "component": { "$codeRef": "BrokerServiceListPage" }
    }
  },
  {
    "type": "console.page/route",
    "properties": {
      "exact": true,
      "path": "/k8s/ns/:ns/brokerservices/~new",
      "component": { "$codeRef": "BrokerServiceCreatePage" }
    }
  },
  {
    "type": "console.resource/create",
    "properties": {
      "model": {
        "group": "broker.arkmq.org",
        "version": "v1beta2",
        "kind": "BrokerService"
      },
      "component": { "$codeRef": "BrokerServiceCreatePage" }
    }
  },
  {
    "type": "console.navigation/href",
    "properties": {
      "id": "example",
      "name": "%plugin__arkmq-org-broker-operator-openshift-ui~Plugin Example%",
      "href": "/example",
      "perspective": "admin",
      "section": "home"
    }
  },
  {
    "type": "console.navigation/resource-ns",
    "properties": {
      "id": "brokerApps",
      "name": "%plugin__arkmq-org-broker-operator-openshift-ui~BrokerApps%",
      "model": {
        "group": "broker.arkmq.org",
        "version": "v1beta2",
        "kind": "BrokerApp"
      },
      "insertAfter": "statefulsets",
      "perspective": "admin",
      "section": "workloads"
    }
  },
  {
    "type": "console.navigation/href",
    "properties": {
      "id": "brokerServices",
      "name": "%plugin__arkmq-org-broker-operator-openshift-ui~BrokerServices%",
      "href": "/k8s/all-namespaces/broker.arkmq.org~v1beta2~BrokerService",
      "insertAfter": "statefulsets",
      "perspective": "admin",
      "section": "workloads"
    }
  }
